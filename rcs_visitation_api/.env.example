# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/rcs_visitation"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-256-bits"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret-key"
JWT_REFRESH_EXPIRES_IN="30d"

# Server
PORT=3000
NODE_ENV=development
API_PREFIX="/api/v1"

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# QR Code (Phase 2)
QR_SECRET="qr-signing-secret"
QR_EXPIRES_HOURS=24
